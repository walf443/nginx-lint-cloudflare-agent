{
  // Worker Loader build of the agent — NO container, so it does NOT require the
  // Workers Paid plan. Config verification runs in an isolated Worker via the
  // Worker Loader API instead of a Sandbox container.
  //
  //   Dev:     npm run dev:loader      (= build:harness + wrangler dev -c ...)
  //   Deploy:  npm run deploy:loader
  //
  // Both verification methods are implemented on this backend (no container):
  // runConfigs (UI playground + auto-verification corpus) and compileAndTest
  // (the authoring build_and_test tool, run in an isolate with node:test shims).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nginx-lint-cloudflare-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],

  "ai": {
    "binding": "AI"
  },

  "vars": {
    "VERIFY_BACKEND": "loader"
  },

  // Worker Loader binding -> available as env.LOADER (open beta).
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],

  // The loader backend imports the bundled isolate harness as Text and the
  // parser core wasm as raw bytes (Data) to inject into the isolate.
  "rules": [
    { "type": "Text", "globs": ["**/*.bundle.txt"], "fallthrough": true },
    { "type": "Data", "globs": ["**/parser.core.wasm"], "fallthrough": true }
  ]
}
