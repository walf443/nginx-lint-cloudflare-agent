{
  // Cloudflare Worker config.
  // Docs: https://developers.cloudflare.com/sandbox/  https://developers.cloudflare.com/workers-ai/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nginx-lint-cloudflare-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],

  // Workers AI binding -> available as env.AI
  "ai": {
    "binding": "AI"
  },

  // Default verification backend (env.VERIFY_BACKEND) when a request doesn't
  // pass a `backend`. Both backends are bound below, so either can be chosen
  // per request from the UI to compare them.
  "vars": {
    "VERIFY_BACKEND": "sandbox"
  },

  // Worker Loader binding -> env.LOADER (loader backend). Both this and the
  // Sandbox container require the Workers Paid plan.
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],

  // Sandbox SDK runs inside a container (Durable Object backed).
  // The Dockerfile MUST extend the cloudflare/sandbox base image whose tag
  // matches the installed @cloudflare/sandbox npm version (see README).
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "name": "sandbox",
      "max_instances": 1,
      "instance_type": "standard-1"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },

  // Durable Object classes require a migration to be declared once.
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    }
  ],

  // src/backends/loader.ts (bundled here via the backend selector even though
  // this build uses the sandbox backend) imports the isolate harness as Text
  // and the parser core wasm as Data; these rules let the bundler resolve them.
  "rules": [
    { "type": "Text", "globs": ["**/*.bundle.txt"], "fallthrough": true },
    { "type": "Data", "globs": ["**/parser.core.wasm"], "fallthrough": true }
  ]
}
